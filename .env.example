# Telegram token from BotFather.
SNABIX_BOT_TOKEN=replace-with-bot-token

# Mode: polling for local development, webhook for ngrok/production.
SNABIX_BOT_MODE=polling

# Snabix backend service API.
SNABIX_BACKEND_BASE_URL=http://127.0.0.1:8080/api/v1
SNABIX_BACKEND_SERVICE_TOKEN=replace-with-backend-service-token

# Comma-separated Telegram user IDs with admin access to /health, /me, /stats.
SNABIX_ADMIN_TELEGRAM_IDS=123456789,987654321

# Webhook settings. Used only when SNABIX_BOT_MODE=webhook.
SNABIX_BOT_WEBHOOK_URL=https://example.ngrok-free.app/webhook/telegram
SNABIX_BOT_WEBHOOK_PATH=/webhook/telegram
SNABIX_BOT_WEBHOOK_SECRET=replace-with-random-webhook-secret
SNABIX_BOT_HOST=0.0.0.0
SNABIX_BOT_PORT=9000

SNABIX_LOG_LEVEL=INFO

# Polling example:
# SNABIX_BOT_MODE=polling
# SNABIX_BOT_WEBHOOK_URL=

# Webhook example with ngrok:
# SNABIX_BOT_MODE=webhook
# SNABIX_BOT_WEBHOOK_URL=https://your-ngrok-domain.ngrok-free.app/webhook/telegram
# SNABIX_BOT_WEBHOOK_PATH=/webhook/telegram
# SNABIX_BOT_WEBHOOK_SECRET=generated-by-openssl-rand-hex-32
# SNABIX_BOT_HOST=0.0.0.0
# SNABIX_BOT_PORT=9000
